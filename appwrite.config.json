{
    "projectId": "chirag-project-prod",
    "projectName": "Main Project",
    "endpoint": "https://sgp.cloud.appwrite.io/v1",
    "settings": {
        "services": {
            "account": true,
            "avatars": true,
            "databases": true,
            "locale": true,
            "health": true,
            "storage": true,
            "teams": true,
            "users": true,
            "sites": true,
            "functions": true,
            "graphql": true,
            "messaging": true
        },
        "auth": {
            "methods": {
                "jwt": true,
                "phone": true,
                "invites": true,
                "anonymous": true,
                "email-otp": true,
                "magic-url": true,
                "email-password": true
            },
            "security": {
                "duration": 31536000,
                "limit": 0,
                "sessionsLimit": 10,
                "passwordHistory": 0,
                "passwordDictionary": false,
                "personalDataCheck": false,
                "sessionAlerts": false,
                "mockNumbers": []
            }
        }
    },
    "sites": [
        {
            "$id": "chirag-profile-website",
            "name": "Profile Website",
            "framework": "tanstack-start",
            "adapter": "static",
            "buildRuntime": "node-22",
            "installCommand": "rm -rf node_modules dist && npm install",
            "buildCommand": "npm run build",
            "outputDirectory": "./dist/client",
            "fallbackFile": "",
            "buildSpecification": "s-4vcpu-4gb",
            "runtimeSpecification": "s-4vcpu-4gb",
            "enabled": true,
            "timeout": 30,
            "logging": true,
            "ignore": null,
            "path": "sites/profile-website",
            "vars": {}
        }
    ]
}
